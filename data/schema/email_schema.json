{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Hacker Evolution Email Schema",
  "description": "Schema for email JSON files in data/emails*.json",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "id": {
        "type": "string",
        "description": "Unique email identifier (optional)"
      },
      "lvl": {
        "type": "integer",
        "minimum": 1,
        "description": "Minimum player level"
      },
      "sub": {
        "type": "string",
        "description": "Email subject line"
      },
      "body": {
        "type": "string",
        "description": "Email body text"
      }
    },
    "required": ["sub", "body"]
  }
}
